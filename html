<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>ExploreX Travels</title>
  <link rel="stylesheet" href="style.css">
</head>
<body>

<nav>
  <a href="#">Home</a>
  <a href="#dest">Destinations</a>
  <a href="#about">About</a>
  <a href="#contact">Contact</a>
</nav>

<header>
  <h1>ExploreX Travels</h1>
  <p>Your dream destination awaits</p>
  <button onclick="scrollToDest()">Explore Now</button>
</header>

<section id="dest">
  <h2>Top Destinations</h2>
  <div class="destinations">
    <div class="card">
      <img src="https://images.unsplash.com/photo-1507525428034-b723cf961d3e">
      <h3>Paris</h3>
    </div>
    <div class="card">
      <img src="https://images.unsplash.com/photo-1512453979798-5ea266f8880c">
      <h3>Dubai</h3>
    </div>
    <div class="card">
      <img src="https://images.unsplash.com/photo-1500530855697-b586d89ba3ee">
      <h3>Maldives</h3>
    </div>
  </div>
</section>

<section id="about">
  <h2>About Us</h2>
  <p>We are a leading tourism agency providing best travel packages worldwide. Affordable, reliable, and memorable experiences.</p>
</section>

<section id="contact">
  <h2>Contact Us</h2>
  <form id="contactForm">
    <input type="text" placeholder="Your Name" required>
    <input type="email" placeholder="Your Email" required>
    <textarea placeholder="Your Message"></textarea>
    <button type="submit">Send</button>
  </form>
</section>

<footer>
  <p>© 2026 ExploreX Travels | All Rights Reserved</p>
</footer>

<script src="script.js"></script>
</body>
</html>
